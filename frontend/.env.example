# Required for production builds: absolute URL of the NestJS API (no trailing slash).
# Example: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:3000

# Optional: when "true", auth token uses sessionStorage so Citizen/Lawyer/Admin can stay logged in per browser tab (testing).
# Omit or "false" for normal localStorage single-session behavior.
VITE_MULTI_SESSION=false

# Optional: embed a YouTube (or youtu.be) link, OR a direct path to an MP4/WebM under `public/` (e.g. /marketing/demo.mp4).
# VITE_HOME_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID
#
# Optional Stripe checkout button (requires backend STRIPE_SECRET_KEY + webhook). Vite uses VITE_ prefix.
# REACT_APP_STRIPE_ENABLED=true is also supported as a CRA-style alias.
# VITE_STRIPE_ENABLED=false
# Optional: local demo file path (served from `public/`). Takes precedence over raw MP4 in VITE_HOME_VIDEO_URL.
# VITE_HOME_HERO_DEMO_FILE=/marketing/lawyerskonnect-demo.mp4
#
# Optional: poster image for the HTML5 video element.
# VITE_HOME_HERO_VIDEO_POSTER=/marketing/demo-poster.jpg
#
# Optional: hero background (path under public/). If unset, tries /marketing/hero.png then /image.png.
# VITE_HOME_HERO_IMAGE=/marketing/custom-hero.webp
