# Copy to .env.prod on your VPS/server before deploy:
#   cp .env.prod.example .env.prod

# === Required ===
JWT_SECRET=change-me-to-a-long-random-secret

# === Public URLs (must match how users open the app) ===
# Option A — Vercel frontend + Docker backend (recommended):
FRONTEND_URL=https://lawyerskonnect.vercel.app
CORS_ORIGINS=https://lawyerskonnect.vercel.app
API_BASE_URL=http://YOUR_SERVER_PUBLIC_IP:3000

# Option B — full stack on one server (same domain or IP):
# FRONTEND_URL=http://YOUR_SERVER_PUBLIC_IP
# CORS_ORIGINS=http://YOUR_SERVER_PUBLIC_IP
# API_BASE_URL=http://YOUR_SERVER_PUBLIC_IP:3000
# VITE_API_BASE_URL=http://YOUR_SERVER_PUBLIC_IP:3000

# === AI chatbot ===
AI_LEGAL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Production uploads ===
# Without Cloudinary, set NODE_ENV=development so KYC/docs save to Docker volume.
# With Cloudinary (recommended for real production):
# NODE_ENV=production
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
NODE_ENV=development

# === Optional ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# GMAIL_USER=
# GMAIL_PASS=
# EMAIL_PROVIDER=gmail

BACKEND_PORT=3000
FRONTEND_PORT=80
