# Copy to .env.public before deploy:
#   cp .env.public.example .env.public
#
# First deploy: leave PUBLIC_URL as placeholder, run ./deploy-public.sh — it prints the
# Cloudflare tunnel URL. Paste that URL below and run ./deploy-public.sh again.

# === Required ===
JWT_SECRET=change-me-to-a-long-random-secret

# === Free HTTPS URL (Cloudflare tunnel — domain khareedne ki zaroorat nahi) ===
# Pehli deploy par placeholder rehne do — ./deploy-public.sh khud URL set kar dega:
PUBLIC_URL=https://YOUR-TUNNEL-URL.trycloudflare.com

# === AI chatbot (recommended for legal guidance demo) ===
AI_LEGAL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === FYP demo: local uploads in Docker volume (no Cloudinary needed) ===
NODE_ENV=development

# === Optional: MongoDB Atlas instead of local mongo container ===
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/lawyerskonnect?retryWrites=true&w=majority

# === Optional ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# EMAIL_PROVIDER=gmail
# GMAIL_USER=
# GMAIL_PASS=

GATEWAY_PORT=8080
