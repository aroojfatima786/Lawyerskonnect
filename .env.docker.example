# Copy to .env.docker and edit before: docker compose up --build
# cp .env.docker.example .env.docker

# === Required ===
JWT_SECRET=change-me-to-a-long-random-secret

# === AI chatbot (recommended for full legal guidance demo) ===
AI_LEGAL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Optional: Stripe (test mode) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# VITE_STRIPE_ENABLED is set at frontend build time in docker-compose.yml if needed

# === Optional: Gmail (default mock — emails print to backend logs) ===
# EMAIL_PROVIDER=gmail
# GMAIL_USER=
# GMAIL_PASS=

# === Optional: Google OAuth ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# === Optional: Cloudinary (not needed — NODE_ENV=development uses local uploads/) ===
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# === Optional: use MongoDB Atlas instead of the local mongo service ===
# Uncomment and set; then remove/disable the mongo service in docker-compose.yml
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/lawyerskonnect?retryWrites=true&w=majority
