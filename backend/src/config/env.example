# MongoDB
MONGODB_URI=mongodb://localhost:27017/lawyerskonnect

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Payments — see root backend/.env.example for full JazzCash/EasyPaisa/card notes.
# manual = demo/manual flows (typical FYP); jazzcash | easypaisa need merchant credentials; card PSP not wired in code.
PAYMENT_PROVIDER=manual

# Cookie Domain (for production)
COOKIE_DOMAIN=

# Email Provider (ses, gmail, or mock)
# - "mock" = logs emails to console (development only)
# - "gmail" = sends emails via Gmail SMTP using Nodemailer
# - "ses" = sends emails via AWS SES
EMAIL_PROVIDER=mock

# Gmail Configuration (required only if EMAIL_PROVIDER=gmail)
# Use an App Password, NOT your regular Gmail password
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# AWS SES Configuration (required only if EMAIL_PROVIDER=ses)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
SES_FROM_EMAIL=noreply@lawyerskonnect.com

# SMS provider (none, mock, twilio)
# Set to 'twilio' to enable real SMS via Twilio
# Set to 'mock' for development logging
# Set to 'none' to disable SMS completely
SMS_PROVIDER=none
SMS_FROM_NUMBER=+1234567890

# Twilio SMS Gateway (required only if SMS_PROVIDER=twilio)
# Get these from https://console.twilio.com
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=

# Optional: External notification webhook
NOTIFICATION_WEBHOOK_URL=

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Cloudinary (required in production for document uploads)
# In development, if these are missing, uploads fall back to local /uploads for backward compatibility.
# In production, upload attempts fail with a clear configuration error when Cloudinary is not configured.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=lawyerskonnect

# Cookie Domain (for production)
COOKIE_DOMAIN=
