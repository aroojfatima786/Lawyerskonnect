# === Required ===
MONGODB_URI=mongodb://localhost:27017/lawyerskonnect
JWT_SECRET=replace-with-strong-secret

# === Server ===
PORT=3000
NODE_ENV=development

# === Auth ===
# Default: use cookie+header as today. "multisession_test" = prefer Bearer header (tab session testing).
# AUTH_MODE=normal
AUTH_MODE=normal

# true = email/OTP sign-in flow; false = direct JWT on signin init (dev convenience when set explicitly).
# In production, set true and configure email if you use OTP.
AUTH_LOGIN_OTP_ENABLED=false

ACCESS_TOKEN_COOKIE_NAME=access_token
COOKIE_DOMAIN=

# === CORS (see main.ts) ===
# Comma-separated allowed browser origins. In production, set CORS_ORIGINS or FRONTEND_URL.
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
# Optional extra dev origins (merged in non-production when CORS_ORIGINS is set; used alone in dev if CORS_ORIGINS is empty)
# CORS_DEV_ORIGINS=http://localhost:5173,http://localhost:3000

# === Public stats / contact / AI (optional) ===
# Legal chat: set OPENAI_API_KEY for cloud AI generation.
# Without OPENAI_API_KEY, chatbot uses knowledge-base + verified-lawyer limited mode (or Ollama if configured).
AI_LEGAL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (local LLM) — optional; set AI_LEGAL_PROVIDER=ollama to use local model
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# FAISS RAG — offline index only (no Python at runtime). Build once:
# npm run setup:legal-rag
# Primary source: Fyp/law download/  (~343 Pakistan Code PDFs, recursive)
# Fallback: backend/law-download/  |  backend/data/laws/
# Index output: backend/data/rag/

# === Payments ===
# PAYMENT_PROVIDER selects the checkout driver for NEW payments (citizens see labels on checkout).
#
# Options:
#   manual    — Recommended for FYP / local demos. Methods show manual transfer or DEMO wallet instructions
#               (not live JazzCash/EasyPaisa/card processing unless you switch provider).
#   jazzcash  — Redirect/checkout via JazzCash; requires ALL JAZZCASH_* variables below.
#   easypaisa — Redirect/checkout via EasyPaisa; requires ALL EASYPAISA_* variables below.
#   card      — NOT a working live card gateway in this codebase (PSP not wired). Admin should use manual
#               or mobile wallets for demos. CARD_* vars alone do not enable checkout.
#
PAYMENT_PROVIDER=manual
PLATFORM_FEE_TYPE=percentage
PLATFORM_FEE_PERCENT=10
PLATFORM_FEE_FIXED=0
AUTO_RELEASE_PAYOUTS=false

# Admin/App wallet receiving details (manual transfer instructions only)
ADMIN_WALLET_BANK_NAME=
ADMIN_WALLET_ACCOUNT_TITLE=LawyersKonnect
ADMIN_WALLET_ACCOUNT_NUMBER=
ADMIN_WALLET_IBAN=
ADMIN_WALLET_JAZZCASH_TITLE=
ADMIN_WALLET_JAZZCASH_NUMBER=
ADMIN_WALLET_EASYPAISA_TITLE=
ADMIN_WALLET_EASYPAISA_NUMBER=

# JazzCash — required when PAYMENT_PROVIDER=jazzcash (sandbox vs production via JAZZCASH_ENV)
JAZZCASH_ENV=sandbox
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
# Public URL of THIS API route (JazzCash redirects the browser here; the API then redirects to FRONTEND_URL).
# Example: http://localhost:3000/payments/return/jazzcash
JAZZCASH_RETURN_URL=
JAZZCASH_WEBHOOK_URL=

# EasyPaisa — required when PAYMENT_PROVIDER=easypaisa (sandbox vs production via EASYPAISA_ENV)
EASYPAISA_ENV=sandbox
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_ACCOUNT_NUM=
# Public API URLs (browser return + server webhook) — e.g. http://localhost:3000/payments/return/easypaisa
EASYPAISA_RETURN_URL=
EASYPAISA_WEBHOOK_URL=
# Optional: hosted checkout form URL (defaults to easypay staging)
# EASYPAISA_CHECKOUT_FORM_URL=https://easypaystg.easypaisa.com.pk/easypay/Index.jsf

# Card — PSP integration not implemented in app code; leave unset for typical FYP demos.
# If set, CardPaymentProvider still blocks live checkout until a real SDK is added.
CARD_PROVIDER=
CARD_SECRET_KEY=
CARD_WEBHOOK_SECRET=
CARD_RETURN_URL=
CARD_WEBHOOK_URL=

# Stripe (optional — parallel to mock/JazzCash/EasyPaisa; does not replace PAYMENT_PROVIDER)
# When set, citizens can use "Pay with Stripe" on checkout if frontend VITE_STRIPE_ENABLED=true.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Public URL for Stripe dashboard webhook: http://localhost:3000/payment/stripe/webhook

# One-time lawyer signup fee (PKR). Paid before email verification / profile setup.
LAWYER_REGISTRATION_FEE=2000

# === Email (verification, OTP when AUTH_LOGIN_OTP_ENABLED=true, notification emails) ===
# mock  — No SMTP; emails print to SERVER CONSOLE ONLY (safest default for demos).
# gmail — Requires GMAIL_USER + GMAIL_PASS (Google “App Password”, not your normal password).
# ses   — Requires AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, SES_FROM_EMAIL.
EMAIL_PROVIDER=mock
GMAIL_USER=
# Gmail SMTP requires a Google App Password (not your normal Gmail password).
GMAIL_PASS=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=

# === SMS (optional notification channel) ===
# none — Outbound SMS disabled (in-app notifications still work).
# mock — Log SMS to server console only (demo).
# twilio — Requires SMS_TWILIO_ACCOUNT_SID, SMS_TWILIO_AUTH_TOKEN, SMS_FROM_NUMBER.
SMS_PROVIDER=none
SMS_FROM_NUMBER=
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# === Other ===
NOTIFICATION_WEBHOOK_URL=

# === Cloudinary (document uploads) ===
# Required in production for KYC/document uploads.
# In development, missing values fall back to local file storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=lawyerskonnect
